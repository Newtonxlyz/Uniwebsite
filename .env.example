# lvyz-platform 环境变量模板
# 复制：cp .env.example .env，填入真实值

# ==================== 应用 ====================
# NEXT_PUBLIC_APP_URL: 本地 dev 用 localhost，Vercel 部署改成 https://lvyz.org
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NODE_ENV: Vercel 自动设 production，不要手动加

# ==================== 数据库 ====================
# 本地开发：SQLite
DATABASE_URL="file:./dev.db"
# 部署到 Vercel：Postgres
# DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ==================== Better Auth ====================
# 生成：openssl rand -hex 32
BETTER_AUTH_SECRET="lvyz-dev-secret-please-change-in-production-2026"
# BETTER_AUTH_URL: dev 用 localhost，Vercel 部署改成 https://lvyz.org
BETTER_AUTH_URL="http://localhost:3000"

# ==================== Cloudflare R2 ====================
# 在 Cloudflare Dashboard → R2 → Create bucket
# API Token: Cloudflare Dashboard → My Profile → API Tokens → Create Custom Token
#   权限: Account:Cloudflare R2:Edit
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="lvyz-media"
R2_PUBLIC_URL="https://media.lvyz.org"
