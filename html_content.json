{"html": "<!DOCTYPE html>\\n<html lang=\"zh-CN\" class=\"dark\">\\n<head><meta charset=\"utf-8\">\\n<style>\\n*{margin:0;padding:0;box-sizing:border-box}\\nhtml.dark{--bg:#0a0a1a;--fg:#e5e7eb;--card-bg:rgba(255,255,255,0.08);--card-border:rgba(255,255,255,0.15);--text-muted:#99a1af;--indigo:#6366f1;--pink:#ec4899;--amber:#f59e0b}\\nbody{background:var(--bg);color:var(--fg);font-family:-apple-system,BlinkMacSystemFont,\\'Segoe UI\\',sans-serif;min-height:100vh}\\n.glass-nav{position:fixed;top:0;left:0;right:0;z-index:50;backdrop-filter:blur(20px);background:rgba(255,255,255,0.06);border-bottom:1px solid rgba(255,255,255,0.1);height:64px;padding:0 24px}\\n.nav-inner{max-width:1200px;margin:0 auto;height:100%;display:flex;align-items:center;justify-content:space-between}\\n.nav-links{display:flex;align-items:center;gap:16px}\\n.nav-links a{color:var(--text-muted);text-decoration:none;font-size:14px;transition:color 0.2s}\\n.nav-links a:hover{color:#fff}\\n.logo{font-size:18px;font-weight:700;background:linear-gradient(135deg,var(--indigo),var(--pink),var(--amber));-webkit-background-clip:text;-webkit-text-fill-color:transparent}\\n.glass-card{backdrop-filter:blur(20px);background:var(--card-bg);border:1px solid var(--card-border);border-radius:16px;padding:24px;transition:all 0.3s}\\n.glass-card:hover{background:rgba(255,255,255,0.12);border-color:rgba(255,255,255,0.25);transform:translateY(-2px)}\\n.text-gradient{background:linear-gradient(135deg,var(--indigo),var(--pink),var(--amber));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}\\nsection{max-width:1024px;margin:0 auto;padding:0 24px}\\n.hero{min-height:80vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding-top:64px;position:relative;overflow:hidden}\\n.hero-glow1{position:absolute;top:-160px;right:-160px;width:320px;height:320px;border-radius:50%;background:rgba(99,102,241,0.08);filter:blur(64px)}\\n.hero-glow2{position:absolute;bottom:-160px;left:-160px;width:320px;height:320px;border-radius:50%;background:rgba(236,72,153,0.08);filter:blur(64px)}\\n.avatar{width:128px;height:128px;border-radius:50%;margin-bottom:24px;background:linear-gradient(135deg,var(--indigo),var(--pink));display:flex;align-items:center;justify-content:center;font-size:48px;backdrop-filter:blur(20px);border:1px solid var(--card-border)}\\nh1{font-size:36px;font-weight:700;margin-bottom:8px}\\n.subtitle{color:var(--text-muted);font-size:18px;margin-bottom:16px}\\n.quote{color:#6a7282;font-size:14px;font-style:italic;margin-bottom:32px;max-width:500px}\\n.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:48px}\\n.card-icon{width:20px;height:20px;margin-bottom:12px;color:var(--indigo)}\\n.card-title{font-size:16px;font-weight:600;margin-bottom:12px}\\n.card-list{list-style:none;display:flex;flex-direction:column;gap:8px}\\n.card-list li{display:flex;align-items:flex-start;gap:8px;font-size:14px;color:var(--text-muted)}\\n.dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:5px;background:var(--indigo)}\\n.section-title{text-align:center;font-size:24px;font-weight:700;margin-bottom:32px}\\n.subsite-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;margin-bottom:96px}\\n.subsite-card{backdrop-filter:blur(20px);background:var(--card-bg);border:1px solid var(--card-border);border-radius:16px;padding:24px;text-decoration:none;color:inherit;position:relative;overflow:hidden;display:block}\\n.subsite-card .icon{font-size:32px;margin-bottom:12px;display:block}\\n.subsite-card h3{font-size:16px;font-weight:600;margin-bottom:4px}\\n.subsite-card p{font-size:14px;color:var(--text-muted)}\\nfooter{border-top:1px solid rgba(255,255,255,0.1);padding:32px 24px;text-align:center}\\nfooter p{color:var(--text-muted);font-size:14px}\\nfooter .email{color:#6a7282;font-size:12px}\\n@media(max-width:768px){.grid-2,.subsite-grid{grid-template-columns:1fr}}\\n</style>\\n</head>\\n<body>\\n<nav class=\"glass-nav\">\\n<div class=\"nav-inner\">\\n<div style=\"display:flex;align-items:center;gap:24px\">\\n<a href=\"/\" class=\"logo\">Lvyz</a>\\n<div class=\"nav-links\">\\n<a href=\"/crashai\">crashAI</a>\\n<a href=\"/kids-ai\">儿童AI</a>\\n<a href=\"/picturebook\">绘本</a>\\n<a href=\"/knowledge-base\">知识库</a>\\n<a href=\"/blog\">博客</a>\\n<a href=\"/merchandise\">IP周边</a>\\n</div></div>\\n<a href=\"/login\" style=\"background:var(--indigo);color:#fff;padding:8px 16px;border-radius:8px;font-size:14px;font-weight:500;text-decoration:none\">登录</a>\\n</div></nav>\\n\\n<div class=\"hero\">\\n<div class=\"hero-glow1\"></div><div class=\"hero-glow2\"></div>\\n<div class=\"avatar\">🐂</div>\\n<h1>吕元卓 · <span class=\"text-gradient\">LYUANZHUO</span></h1>\\n<p class=\"subtitle\">车辆安全 × AI应用工程师 · 14年专业经验</p>\\n<p class=\"quote\">&ldquo;正在从传统工程向AI转型，目标百万年薪&rdquo;</p>\\n<div style=\"display:flex;gap:12px\">\\n<span style=\"backdrop-filter:blur(20px);background:var(--card-bg);border:1px solid var(--card-border);border-radius:999px;padding:8px 20px;font-size:14px;font-weight:500\">📄 下载简历</span>\\n<span style=\"backdrop-filter:blur(20px);background:var(--card-bg);border:1px solid var(--card-border);border-radius:999px;padding:8px 20px;font-size:14px;color:var(--text-muted)\">📧 联系我</span>\\n</div></div>\\n\\n<section>\\n<div class=\"grid-2\">\\n<div class=\"glass-card\">\\n<div style=\"color:var(--indigo);margin-bottom:12px\">\\n<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z\"/><path d=\"M22 10v6\"/><path d=\"M6 12.5V16a6 3 0 0 0 12 0v-3.5\"/></svg>\\n</div>\\n<h3 class=\"card-title\">教育背景</h3>\\n<ul class=\"card-list\">\\n<li><span class=\"dot\"></span>西安交通大学 · 工程力学学士 + 航天工程硕士</li>\\n<li><span class=\"dot\"></span>211/985 TOP10 | 2006-2012</li>\\n<li><span class=\"dot\"></span>英语B2.2 · 德语B2.2（自学）</li>\\n</ul></div>\\n\\n<div class=\"glass-card\">\\n<div style=\"color:#10b981;margin-bottom:12px\">\\n<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16\"/><rect width=\"20\" height=\"14\" x=\"2\" y=\"6\" rx=\"2\"/></svg>\\n</div>\\n<h3 class=\"card-title\">职业经历</h3>\\n<ul class=\"card-list\">\\n<li><span class=\"dot\"></span>一汽-大众 · 车辆安全 · 14年专业经验</li>\\n<li><span class=\"dot\"></span>驻奥迪团队领队 | A3/A4/A6/Q2/Q3/Q5/C-BEV/ASUVe</li>\\n<li><span class=\"dot\"></span>约束系统开发 | 项目管理 | CNCAP/C-IASI专家</li>\\n</ul></div>\\n\\n<div class=\"glass-card\">\\n<div style=\"color:#06b6d4;margin-bottom:12px\">\\n<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z\"/></svg>\\n</div>\\n<h3 class=\"card-title\">专业技能</h3>\\n<ul class=\"card-list\">\\n<li><span class=\"dot\"></span>ANSA | Pamcrash | EVA | Falcon | MADYMO</li>\\n<li><span class=\"dot\"></span>HTML/CSS/JS | Bootstrap | Python | Power BI</li>\\n<li><span class=\"dot\"></span>LS-DYNA | 碰撞安全仿真 | 数据分析</li>\\n</ul></div>\\n\\n<div class=\"glass-card\">\\n<div style=\"color:#f43f5e;margin-bottom:12px\">\\n<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><circle cx=\"12\" cy=\"12\" r=\"6\"/><circle cx=\"12\" cy=\"12\" r=\"2\"/></svg>\\n</div>\\n<h3 class=\"card-title\">当前目标</h3>\\n<ul class=\"card-list\">\\n<li><span class=\"dot\"></span>华为鸿蒙智行BU · 18-19级（AI应用工程师）</li>\\n<li><span class=\"dot\"></span>副业产品化 · 百万年薪 · 持续学习</li>\\n<li><span class=\"dot\"></span>从传统工程向AI转型，用技术创造价值</li>\\n</ul></div>\\n</div>\\n\\n<h2 class=\"section-title\">🗺️ <span class=\"text-gradient\">站点导航</span></h2>\\n<div class=\"subsite-grid\">\\n<a href=\"/crashai\" class=\"subsite-card\">\\n<span class=\"icon\">🎓</span>\\n<h3>AI学习</h3>\\n<p>24主题 · 157张卡片 · AI转行作战包</p>\\n</a>\\n\\n<a href=\"/kids-ai\" class=\"subsite-card\">\\n<span class=\"icon\">🧒</span>\\n<h3>儿童学堂</h3>\\n<p>AI启蒙 · 创意工坊 · 成就系统</p>\\n</a>\\n\\n<a href=\"/picturebook\" class=\"subsite-card\">\\n<svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"hsla(0,0%,100%,0.8)\" stroke-width=\"2\" style=\"margin-bottom:12px\"><path d=\"M12 7v14\"/><path d=\"M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z\"/></svg>\\n<h3>绘本</h3>\\n<p>雷迪嘎嘎系列 · 1840个故事</p>\\n</a>\\n\\n<a href=\"/knowledge-base\" class=\"subsite-card\">\\n<svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"hsla(0,0%,100%,0.8)\" stroke-width=\"2\" style=\"margin-bottom:12px\"><ellipse cx=\"12\" cy=\"5\" rx=\"9\" ry=\"3\"/><path d=\"M3 5V19A9 3 0 0 0 21 19V5\"/><path d=\"M3 12A9 3 0 0 0 21 12\"/></svg>\\n<h3>知识库</h3>\\n<p>Dify RAG · 车辆安全 · 技术文档</p>\\n</a>\\n\\n<a href=\"/blog\" class=\"subsite-card\">\\n<svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"hsla(0,0%,100%,0.8)\" stroke-width=\"2\" style=\"margin-bottom:12px\"><path d=\"M13 21h8\"/><path d=\"M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z\"/></svg>\\n<h3>博客</h3>\\n<p>技术笔记 · 学习心得 · 行业观点</p>\\n</a>\\n\\n<a href=\"/merchandise\" class=\"subsite-card\">\\n<svg width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"hsla(0,0%,100%,0.8)\" stroke-width=\"2\" style=\"margin-bottom:12px\"><path d=\"M16 10a4 4 0 0 1-8 0\"/><path d=\"M3.103 6.034h17.794\"/><path d=\"M3.4 5.467a2 2 0 0 0-.4 1.2V20a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6.667a2 2 0 0 0-.4-1.2l-2-2.667A2 2 0 0 0 17 2H7a2 2 0 0 0-1.6.8z\"/></svg>\\n<h3>IP周边</h3>\\n<p>学习产品 · 知识变现 · 未来</p>\\n</a>\\n</div>\\n</section>\\n\\n<footer>\\n<p>© 2026 吕元卓 · lvyuanzhuo@hotmail.com</p>\\n<p style=\"color:#6a7282;font-size:12px;margin-top:4px\">+86-150-4306-8993 | 不断学习 · 持续进化</p>\\n</footer>\\n</body></html>\\n"}