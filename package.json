{
    "name":  "lvyz-platform",
    "version":  "0.2.0",
    "private":  true,
    "description":  "lvyz.org monorepo · Next.js 16 + Better Auth + Prisma + R2",
    "scripts":  {
                    "dev":  "next dev",
                    "build":  "prisma generate \u0026\u0026 next build",
                    "start":  "next start",
                    "lint":  "eslint",
                    "typecheck":  "tsc --noEmit",
                    "db:generate":  "prisma generate",
                    "db:push":  "prisma db push",
                    "db:migrate":  "prisma migrate dev",
                    "db:studio":  "prisma studio",
                    "db:seed":  "tsx prisma/seed.ts",
                    "prebuild":  "pnpm approve-builds --all || true"
                },
    "dependencies":  {
                         "@aws-sdk/client-s3":  "^3.703.0",
                         "@aws-sdk/s3-request-presigner":  "^3.703.0",
                         "@prisma/client":  "^6.1.0",
                         "@tailwindcss/postcss":  "^4.3.0",
                         "bcryptjs":  "^2.4.3",
                         "better-auth":  "^1.1.0",
                         "clsx":  "^2.1.1",
                         "date-fns":  "^4.1.0",
                         "lucide-react":  "^1.17.0",
                         "next":  "16.2.9",
                         "pg":  "^8.21.0",
                         "react":  "19.2.7",
                         "react-dom":  "19.2.7",
                         "react-markdown":  "^10.1.0",
                         "react-syntax-highlighter":  "^16.1.1",
                         "remark-gfm":  "^4.0.1",
                         "server-only":  "^0.0.1",
                         "tailwind-merge":  "^3.6.0",
                         "tailwindcss":  "^4.3.0",
                         "tw-animate-css":  "^1.4.0",
                         "zod":  "^3.24.1"
                     },
    "devDependencies":  {
                            "@types/bcryptjs":  "^2.4.6",
                            "@types/node":  "20.19.43",
                            "@types/react":  "19.2.17",
                            "@types/react-dom":  "^19",
                            "@types/react-syntax-highlighter":  "^15.5.13",
                            "eslint":  "^9",
                            "eslint-config-next":  "16.2.9",
                            "prisma":  "^6.1.0",
                            "tsx":  "^4.19.2",
                            "typescript":  "5.9.3"
                        }
}
